# Connexion à la base PostgreSQL Neon.
# DATABASE_URL : connexion « pooled » (hôte contenant "-pooler").
# DIRECT_URL   : connexion directe (sans "-pooler"), utilisée pour les migrations.
DATABASE_URL=""
DIRECT_URL=""
# Authentification admin (lib/session.ts + lib/mot-de-passe.ts)
# AUTH_SECRET : clé HS256 pour signer le JWT de session. Générer avec :
#   openssl rand -base64 48
AUTH_SECRET=""
# ADMIN_PASSWORD_HASH : empreinte bcrypt du mot de passe admin, encodée en
# base64 (cf. scripts/ pour la génération). L'encodage évite que les « $ »
# soient interprétés comme variables au chargement du .env.
ADMIN_PASSWORD_HASH=""

# Stockage des médias (photos / documents) sur Vercel Blob.
# Récupérer le token depuis le projet Vercel > Storage > Blob > Connect Project.
BLOB_READ_WRITE_TOKEN=""

